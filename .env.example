# =============================================================================
# Sales Intel Agent — Environment Variable Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Sales Intel Agent"
DEBUG=false


# -----------------------------------------------------------------------------
# File storage
# -----------------------------------------------------------------------------

# Public base URL used to construct local file download links.
# Leave empty when running behind a reverse proxy that sets the host header.
BASE_URL=http://localhost:8080

# Local directory where file-index metadata is stored.
UPLOAD_DIR=uploads

# Maximum accepted file size in megabytes.
MAX_FILE_SIZE_MB=5

# Maximum number of files a single user can upload at once.
MAX_FILE_UPLOAD_COUNT=1

# Seconds until a presigned S3 URL expires.
FILE_URL_EXPIRY_SECONDS=3600


# -----------------------------------------------------------------------------
# API metadata exposed at GET /metadata
# -----------------------------------------------------------------------------
DEFAULT_MODEL=gpt-5 mini


# -----------------------------------------------------------------------------
# LLM — DataRobot / OpenAI-compatible endpoint
# -----------------------------------------------------------------------------

# API token for the DataRobot deployment.
DATAROBOT_API_TOKEN=your_datarobot_api_token_here

# Full URL of the OpenAI-compatible chat completions endpoint.
# Example: https://app.datarobot.com/api/v2/deployments/<id>/chat/completions
CHAT_API_URL=https://your-datarobot-deployment-url/api/v1/chat/completions

# Model identifier forwarded to the LLM API.
# Override this to switch deployments without code changes.
LLM_MODEL=datarobot-deployed-llm


# -----------------------------------------------------------------------------
# AWS / S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
REGION_NAME=ap-southeast-2

# S3 bucket used for storing uploaded files and generated PDF reports.
AWS_BUCKET=s3-ai-demo-bucket


# -----------------------------------------------------------------------------
# Mermaid / PDF rendering
# -----------------------------------------------------------------------------

# Absolute path to a custom Puppeteer config JSON.
# Leave empty to use the bundled default at app/services/puppeteer-config.json.
# Override in production to point to your Chrome/Chromium binary location.
# Example: /home/user/.cache/puppeteer/chrome-headless-shell/.../chrome-headless-shell
PUPPETEER_CONFIG_PATH=
